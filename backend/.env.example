# ── NEUFood chatbot (Gemini) ─────────────────────────────────────────
# Sao chép file này thành .env trong cùng thư mục backend:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (macOS/Linux)
# Điền khóa thật vào .env — KHÔNG commit file .env lên Git.

# Bắt buộc: API key Google AI (Gemini)
# Tạo / quản lý tại: https://aistudio.google.com/apikey
# Model gợi ý: gemini-1.5-flash (nhanh, rẻ) | gemini-1.5-pro (sâu hơn)
# Nếu lỗi "model not found", thử đổi model hoặc kiểm tra tên trên Google AI Studio.
GEMINI_MODEL=gemini-1.5-flash

# Tuỳ chọn: độ sáng tạo câu trả lời (0–1, mặc định 0.65)
GEMINI_TEMPERATURE=0.65

# Tuỳ chọn: giới hạn độ dài một lần trả lời (token)
GEMINI_MAX_OUTPUT_TOKENS=1024

# Tuỳ chọn: nhân cách / nhiệm vụ bot (để trống = dùng prompt mặc định NEUFood tiếng Việt)
# Viết một đoạn, có thể nhiều dòng bằng \n trong .env hoặc dùng dấu ngoặc — đơn giản nhất: một dòng ngắn.
# GEMINI_SYSTEM_PROMPT=Bạn là trợ lý NEUFood, chỉ trả lời ngắn gọn bằng tiếng Việt.

# Cổng HTTP của Express
PORT=3000
